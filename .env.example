# =====================================================================
# dhow — environment template. Copy to .env and fill REAL values.
# NEVER commit .env. All addresses/keys are config, never hardcoded.
# =====================================================================

# ---- Chain / RPC (Polygon Amoy testnet → mainnet by swapping these) ----
CHAIN_ID=80002
RPC_URL=https://rpc-amoy.polygon.technology
# Block explorer API key (Polygonscan) for contract verification
ETHERSCAN_API_KEY=

# ---- Deployer (use a dedicated testnet key; NEVER a personal mainnet key) ----
DEPLOYER_PRIVATE_KEY=

# ---- Token addresses (real, per network) ----
# Amoy USDC (set the canonical testnet USDC you will use)
USDC_ADDRESS=

# ---- Protocol roles (addresses) ----
# Backend operator that triggers disbursements after off-chain underwriting
OPERATOR_ADDRESS=
# Licensed funder permitted to deposit liquidity
FUNDER_ADDRESS=

# ---- Account abstraction (Phase 4) — real bundler/paymaster ----
BUNDLER_URL=
PAYMASTER_URL=

# ---- Open finance (Phase 3/4) — Lean sandbox ----
LEAN_APP_TOKEN=
LEAN_BASE_URL=https://sandbox.leantech.me

# ---- Off-ramp / USDC<->AED (Phase 4) — pending partner credentials ----
OFFRAMP_API_URL=
OFFRAMP_API_KEY=

# ---- Backend (Phase 2) ----
NODE_ENV=development
DATABASE_URL=postgresql://dhow:dhow@localhost:5432/dhow?schema=public
API_PORT=4000
JWT_SECRET=

# ---- Backend chain wiring (api operator + deployed contract addresses) ----
# OPERATOR must hold OPERATOR_ROLE on FinancingPool and REGISTRAR_ROLE/VERIFIER_ROLE on InvoiceRegistry.
OPERATOR_PRIVATE_KEY=
INVOICE_REGISTRY_ADDRESS=
FINANCING_POOL_ADDRESS=
REPUTATION_REGISTRY_ADDRESS=
