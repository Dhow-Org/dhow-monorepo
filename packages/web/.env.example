# dhow web — build-time vars (VITE_ prefix). Never put secrets here.

# API base URL.
#  - Local dev: leave as /api (the Vite dev server proxies to http://localhost:4000).
#  - Production (Vercel): set to your Railway API URL + /api,
#    e.g. https://dhow-api-production.up.railway.app/api
VITE_API_URL=/api

# USDC token address on the target chain (must match the deployed FinancingPool asset).
# Amoy test USDC (current deployment):
VITE_USDC_ADDRESS=0xdC48E5e5c3Cf91b6db9ec0f329a14188174632C2
