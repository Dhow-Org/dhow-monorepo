{
  "name": "@dhow/api",
  "version": "0.0.0",
  "private": true,
  "description": "dhow backend: domain services, chain client, and REST API (NestJS).",
  "license": "UNLICENSED",
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.build.json",
    "lint": "tsc --noEmit -p tsconfig.json",
    "start": "node dist/main.js",
    "start:dev": "tsx watch src/main.ts",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "test": "tsx test/cashflow.test.ts && tsx test/offramp.test.ts"
  },
  "dependencies": {
    "@dhow/shared": "workspace:*",
    "@dhow/underwriting": "workspace:*",
    "@nestjs/common": "^10.4.4",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.4",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.4.4",
    "@nestjs/swagger": "^7.4.2",
    "@prisma/client": "^5.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "siwe": "^2.3.2",
    "viem": "^2.21.19",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "prisma": "^5.20.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
